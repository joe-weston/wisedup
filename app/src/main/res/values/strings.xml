<?xml version="1.0" encoding="utf-8"?>
<resources>
    <string name="app_name">WizedUp Focus</string>

    <!-- Accessibility service label + description (shown in system Settings). -->
    <string name="accessibility_service_label">WizedUp Focus</string>
    <string name="accessibility_service_description">WizedUp Focus uses the Android Accessibility API to detect when another app comes to the foreground while Focus Mode is active and to bring the focus screen back. We only watch for window-state changes; we never read content from other apps. This permission is required for Focus Mode to work.</string>

    <!-- Onboarding (US-R1-03). -->
    <string name="onboarding_title">Welcome to WizedUp</string>
    <string name="onboarding_subtitle">Focus is voluntary. You can exit any time.</string>
    <string name="onboarding_name_label">Name or student ID</string>
    <string name="onboarding_name_placeholder">e.g. Alex M. or 12345</string>
    <string name="onboarding_continue">Continue</string>
    <string name="onboarding_name_counter">%1$d / %2$d</string>

    <!-- Home screen (US-R1-04). -->
    <string name="home_greeting">Hey, %1$s</string>
    <string name="home_status_off">Focus Off</string>
    <string name="home_status_on">Focus Active</string>
    <string name="home_activate_button">Activate Focus</string>
    <string name="home_subtitle_off">Tap to lock your phone to the focus screen.</string>

    <!-- Permission rationale (US-R1-05). -->
    <string name="permission_dialog_title">One-time setup</string>
    <string name="permission_dialog_body">WizedUp uses Android Accessibility to keep you on the focus screen. Tap Open Settings, find WizedUp, and turn it on. Then come back.</string>
    <string name="permission_dialog_open_settings">Open Settings</string>
    <string name="permission_dialog_cancel">Cancel</string>
    <string name="notification_permission_required">Notification permission required to show focus status.</string>

    <!-- Focus screen (US-R1-06). -->
    <string name="focus_active_title">Focus Active</string>
    <string name="focus_active_subtitle">You’re focused</string>
    <string name="focus_active_name">%1$s</string>
    <string name="focus_active_elapsed_short">%1$02d:%2$02d</string>
    <string name="focus_active_elapsed_long">%1$02d:%2$02d:%3$02d</string>
    <string name="focus_exit_button">Exit Focus</string>

    <!-- Exit confirm dialog (US-R1-10). Verbatim copy from the story spec. -->
    <string name="exit_dialog_title">Exit Focus Mode?</string>
    <string name="exit_dialog_body">Your session will be logged in a future release.</string>
    <string name="exit_dialog_confirm">Exit</string>
    <string name="exit_dialog_dismiss">Stay focused</string>

    <!-- Foreground service notification (US-R1-07, US-R1-09). -->
    <string name="notification_channel_name">Focus Mode</string>
    <string name="notification_channel_description">Shown while WizedUp Focus is active so you always know your status.</string>
    <string name="notification_title">Focus Mode active</string>
    <string name="notification_text">Tap to return to focus screen</string>

    <!-- Misc -->
    <string name="content_description_status_indicator">Focus status indicator</string>
</resources>
