<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ Auto Backup / D2D transfer exclusions.
  See ADR-004 §Consequences and US-R1-14 AC: a restored device must NOT inherit the
  prior student's UUID or display name. Excluding the DataStore preferences file
  achieves that.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="datastore/wisedup_state.preferences_pb" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="datastore/wisedup_state.preferences_pb" />
    </device-transfer>
</data-extraction-rules>
