<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Focus Off — green token (US-R1-13). WCAG AA contrast against light/dark backgrounds. -->
    <color name="focus_off_green">#FF1B873F</color>
    <color name="focus_off_green_container">#FFD2F5DC</color>
    <color name="focus_off_on_green">#FFFFFFFF</color>

    <!-- Focus Active — red/amber tokens. We use a deep amber (warmer than pure red) for
         legibility in dark mode while still reading as "stop / locked". -->
    <color name="focus_active_red">#FFC8262C</color>
    <color name="focus_active_amber">#FFE08A1A</color>
    <color name="focus_active_on">#FFFFFFFF</color>

    <!-- Surface tokens. -->
    <color name="surface_light">#FFFFFFFF</color>
    <color name="surface_dark">#FF121212</color>
    <color name="on_surface_light">#FF1A1A1A</color>
    <color name="on_surface_dark">#FFEDEDED</color>

    <!-- Notification icon tint: amber so the OS-rendered small icon reads as "active". -->
    <color name="notification_icon_tint">#FFE08A1A</color>
</resources>
